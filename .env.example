# ── Backend ──────────────────────────────
PORT=3000
NODE_ENV=production

# ── MySQL ─────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=flowgen
MYSQL_USER=flowgen
MYSQL_PASSWORD=FlowGen@2025!

# ── JWT ───────────────────────────────────
JWT_SECRET=cambia-esto-por-algo-seguro
JWT_EXPIRES_IN=8h

# ── VM Worker ─────────────────────────────
# IP o hostname de la máquina virtual que corre el bot
VM_WORKER_URL=http://192.168.1.X:8000

# ── CORS ──────────────────────────────────
CLIENT_URL=*
